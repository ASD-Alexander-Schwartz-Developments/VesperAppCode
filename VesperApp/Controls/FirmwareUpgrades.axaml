<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:m="using:VesperApp.Models"
             xmlns:vm="using:VesperApp.ViewModels"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:si="clr-namespace:SatialInterfaces.Controls;assembly=CalendarControl"
             xmlns:Controls="using:VesperApp.Controls"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="450"
             x:Class="VesperApp.Controls.FirmwareUpgrades">

	<UserControl.Resources>
		<ui:PathIconSource x:Key="FwUpdate" Data="M12.7475726,4.00121916 L12.747,4.00321916 L20.2451452,4.00365747 C21.2116435,4.00365747 21.9951452,4.78715916 21.9951452,5.75365747 L21.9951452,18.2487808 C21.9951452,19.2152792 21.2116435,19.9987808 20.2451452,19.9987808 L11.2475726,19.9987808 L11.247,19.9962192 L3.75,19.9963425 C2.78350169,19.9963425 2,19.2128408 2,18.2463425 L2,5.75121916 C2,4.78472085 2.78350169,4.00121916 3.75,4.00121916 L12.7475726,4.00121916 Z M20.2451452,5.50365747 L12.7475726,5.50365747 L12.7475726,18.4987808 L20.2451452,18.4987808 C20.3832163,18.4987808 20.4951452,18.386852 20.4951452,18.2487808 L20.4951452,5.75365747 C20.4951452,5.61558629 20.3832163,5.50365747 20.2451452,5.50365747 Z M11.2475726,5.50121916 L3.75,5.50121916 C3.61192881,5.50121916 3.5,5.61314797 3.5,5.75121916 L3.5,18.2463425 C3.5,18.3844137 3.61192881,18.4963425 3.75,18.4963425 L11.2475726,18.4963425 L11.2475726,5.50121916 Z M16.5,7 C16.8807533,7 17.1954225,7.28157829 17.2452233,7.64690706 L17.252089,7.74847001 L17.2514197,14.4457796 L18.2161038,13.4866361 C18.483112,13.2209127 18.9009362,13.1967561 19.1953655,13.4141661 L19.2797182,13.4866361 C19.5467264,13.7523595 19.5709999,14.1681732 19.3525387,14.4611857 L19.2797182,14.5451325 L17.0318072,16.7822269 L16.9935092,16.8177893 L16.9308261,16.8666285 L16.8641102,16.9080431 L16.8034199,16.9380467 L16.7024386,16.974019 L16.6396646,16.9885031 L16.5469168,17 L16.4530706,17 L16.3610842,16.988707 L16.2644926,16.9640199 L16.1525707,16.9170239 L16.0755079,16.8709193 L15.9681928,16.7822269 L13.7202818,14.5451325 C13.4265727,14.2528368 13.4265727,13.7789318 13.7202818,13.4866361 C13.9872899,13.2209127 14.4051142,13.1967561 14.6995434,13.4141661 L14.7838962,13.4866361 L15.7472418,14.4457796 L15.747911,7.74847001 C15.747911,7.4039962 15.9817456,7.11387457 16.300065,7.02673607 L16.397946,7.00683265 L16.5,7 Z" />
	</UserControl.Resources>
	
	<HeaderedContentControl Header="Firmware Upgrades" IsVisible="True" UseLayoutRounding="True">
		<Grid Background="{DynamicResource ApplicationPageBackgroundThemeBrush}" HorizontalAlignment="Stretch" ColumnDefinitions="*" RowDefinitions="60,*">
			<ui:CommandBar DefaultLabelPosition="Right" Grid.Row="0">
				<ui:CommandBar.PrimaryCommands>
					<ui:CommandBarElementContainer>
						<ComboBox x:Name="comboDeviceType"
								Margin="10"
								VerticalAlignment="Center"
								Width="140"
								ItemsSource="{Binding Source={m:EnumBindingSource {x:Type m:DeviceTypes}}}"
								SelectedItem="{Binding SelectedDeviceType}"/>
					</ui:CommandBarElementContainer>
					<ui:CommandBarButton Command="{Binding RefreshReleasesCommand}" IconSource="{StaticResource FwUpdate}" Label="Refresh" ToolTip.Tip="Refresh List of Releases"/>
					<ui:CommandBarSeparator />
					<ui:CommandBarButton Command="{Binding DownloadReleaseCommand}" IconSource="Download" Label="Download" ToolTip.Tip="Download Update"/>				
				</ui:CommandBar.PrimaryCommands>
			
				<ui:CommandBar.SecondaryCommands>
				</ui:CommandBar.SecondaryCommands>
			</ui:CommandBar>

			<Grid Grid.Row="1" RowDefinitions="Auto,*" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
				<VirtualizingStackPanel Grid.Row="1">
					<ui:ProgressRing IsVisible="{Binding IsLoadingReleases}" IsActive="{Binding IsLoadingReleases}" Margin="10,0,0,0" Grid.Row="0"/>
				</VirtualizingStackPanel>
			
				<dg:DataGrid Grid.Row="1"
							 ItemsSource="{Binding Releases}"
							 x:Name="listReleasesList"
							 Margin="20"
							 SelectionMode="Single"
							 SelectedItem="{Binding SelectedFirmwareRelease, Mode=TwoWay}"
							 AutoGenerateColumns="False"
							 IsReadOnly="True"
							 HeadersVisibility="Column"
							 GridLinesVisibility="None"
							 HorizontalAlignment="Stretch"
							 VerticalAlignment="Stretch"
							 CanUserResizeColumns="True"
							 CanUserReorderColumns="False"
							 CanUserSortColumns="False"
							 VerticalScrollBarVisibility="Visible"
							 HorizontalScrollBarVisibility="Auto">
					<dg:DataGrid.Resources>
						<Style x:Key="1" Selector="DataGridColumnHeader">
							<Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}"/>
							<Setter Property="Padding" Value="12,0"/>
							<Setter Property="HorizontalContentAlignment" Value="Left"/>
							<Setter Property="FontWeight" Value="Bold"/>
						</Style>
					</dg:DataGrid.Resources>

					<dg:DataGrid.Columns>
						<dg:DataGridTextColumn Header="Ver" Binding="{Binding Name}" Width="1*" MinWidth="80"/>
						<dg:DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" MinWidth="200"/>
						<dg:DataGridTextColumn Header="Publish Date" Binding="{Binding Published}" Width="2*" MinWidth="120"/>
					</dg:DataGrid.Columns>
				</dg:DataGrid>
			</Grid>
		</Grid>	
	</HeaderedContentControl>

</UserControl>
