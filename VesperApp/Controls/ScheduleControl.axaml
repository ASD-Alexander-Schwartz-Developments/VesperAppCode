<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	         xmlns:vm="using:VesperApp.ViewModels"
			 xmlns:m="using:VesperApp.Models"
			 xmlns:c="using:VesperApp.Controls"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="340"
             x:Class="VesperApp.Controls.ScheduleControl"
			 MinHeight="340" BorderThickness="1" BorderBrush="{DynamicResource ThemeBorderMidBrush}">

	
	<DockPanel Margin="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
		<StackPanel Background="{DynamicResource ThemeControlMidHighBrush}" Spacing="3" Orientation="Horizontal" HorizontalAlignment="Stretch" DockPanel.Dock="Top">
			<Label Margin="20,10" Content="Select Schedule Type" VerticalAlignment="Center"/>
			<ComboBox x:Name="comboScheduleType"
					  SelectedIndex="0" Margin="1"
					  VerticalAlignment="Center"
					  Width="120"
					  Items="{Binding Source={m:EnumBindingSource {x:Type m:ScheduleTypes}}}"
					  SelectionChanged="OnSelectionChanged_ScheduleType"/>
		</StackPanel>

		<StackPanel Margin="1" Orientation="Vertical" DockPanel.Dock="Right" IsEnabled="True">
			<StackPanel Orientation="Vertical" VerticalAlignment="Top">
				<CheckBox x:Name="cbIsPoweronRelative" IsThreeState="False" IsChecked="{Binding IsPowerOnRelative}" ToolTip.Tip="When checked, PowerOn uses relative timing (magnet activation is time 0)"> 
					Is Relative 
				</CheckBox>
				<Label Content="Power ON trigger time"/>
				<MaskedTextBox Text="{Binding PowerOnText}" Mask="{Binding PowerOnEditMask}" Focusable="True"/>
			</StackPanel>
		</StackPanel>

		<StackPanel Margin="1,10,30,0" Orientation="Vertical" DockPanel.Dock="Right" IsEnabled="{Binding IsAddingNewEntry}">
			<StackPanel Orientation="Vertical" VerticalAlignment="Center">
				<DatePicker IsEnabled="{Binding IsDateEnabled}" 
							MonthVisible="{Binding IsMonthVisible}"
							YearVisible="{Binding IsYearVisible}"
							DayVisible="{Binding IsDayVisible}"
							SelectedDate="{Binding SelectedDate, Mode=TwoWay}" 
							FontFamily="Lato" FontSize="12" 
							x:Name="dpDate" 
							VerticalAlignment="Center" Padding="0,0,0,14" />
				<TimePicker SelectedTime="{Binding SelectedTime, Mode=TwoWay}" 
							FontFamily="Lato" FontSize="12" 
							x:Name="tpTime"
							VerticalAlignment="Center" 
							Padding="0,0,0,14" ClockIdentifier="24HourClock"/>
			</StackPanel>
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Label Content="Select Configuration" VerticalAlignment="Center"/>
				<ComboBox x:Name="comboConfig"
						  SelectedIndex="0" Margin="1"
						  VerticalAlignment="Center"
						  Width="100"
						  SelectedItem="{Binding SelectedConfiguration, Mode=TwoWay}"
						  Items="{Binding Source={m:EnumBindingSource {x:Type m:WorkingConfiguration}}}"/>
			</StackPanel>
			<StackPanel Margin="1,28,10,10" Spacing="5" Orientation="Horizontal" HorizontalAlignment="Center">
				<Button x:Name="btnApply" HorizontalAlignment="Center" Margin="0" Command="{Binding CommandApplyButton}">
					<Image Width="26" Height="26">
						<Image.Source>
							<DrawingImage Drawing="{DynamicResource FluentIconsFilled.text_change_accept_filled}"/>
						</Image.Source>
					</Image>
				</Button>
				<Button x:Name="btnCancel" HorizontalAlignment="Center" Margin="0" Command="{Binding CommandRejectButton}">
					<Image Width="26" Height="26">
						<Image.Source>
							<DrawingImage Drawing="{DynamicResource FluentIconsFilled.text_change_reject_filled}" />
						</Image.Source>
					</Image> 
				</Button>
			</StackPanel>
		</StackPanel>

		<StackPanel Margin="1,10,30,0" Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinWidth="265" DockPanel.Dock="Left">
			<Label Content="Operating Schedule Alarms"/>
			<Border BorderBrush="AntiqueWhite" BorderThickness="1">
			<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
			<ListBox Items="{Binding ScheduleEventsList}" 
					 x:Name="listScheduleEventsList" 
					 Margin="1,1,1,1" 
					 SelectionMode="Single" 
					 SelectedIndex="{Binding SelectedIndex}"
					 MinWidth="260"
					 MinHeight="200"
					 HorizontalAlignment="Stretch"
					 VerticalAlignment="Stretch"
					 Background="{DynamicResource ThemeControlMidHighBrush}">
				<ListBox.ItemTemplate>
					<DataTemplate DataType="m:ConfigScheduleJSONItem">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>
							<StackPanel Margin="1,1,1,1" Orientation="Horizontal" Spacing="5">
								<TextBlock Text="{Binding Alarm, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" FontFamily="Lato" FontSize="12" />
								<TextBlock Text="{Binding ConfigName}" TextWrapping="Wrap" FontWeight="Bold" FontFamily="Lato" FontSize="12" />
							</StackPanel>
						</Grid>
					</DataTemplate>
				</ListBox.ItemTemplate>
				<ListBox.Styles>
					<!-- Give the ListBoxItems a fixed with of 100 and right-align them -->
					<Style Selector="ListBoxItem">
						<!--
						<Setter Property="Width" Value="200"/>
						<Setter Property="Height" Value="30"/>-->
						<Setter Property="HorizontalAlignment" Value="Stretch"/>
					</Style>
				</ListBox.Styles>
			</ListBox>
			</ScrollViewer>
			</Border>
			<StackPanel Margin="5" Spacing="5" Orientation="Horizontal" HorizontalAlignment="Left">
				<Button x:Name="btnUp" Command="{Binding CommandUpButton}" >
					<Image Width="26" Height="26">
						<Image.Source>
							<DrawingImage Drawing="{DynamicResource FluentIconsFilled.arrow_up_filled}" /> 
						</Image.Source>
					</Image>  
				</Button>
				<Button x:Name="btnAdd" Command="{Binding CommandAddButton}">
					<Image Width="26" Height="26">
						<Image.Source>
							<DrawingImage Drawing="{DynamicResource FluentIconsFilled.calendar_add_filled}" />
						</Image.Source>
					</Image> 
				</Button>
				<Button x:Name="btnDelete" Command="{Binding CommandDeleteButton}" >
					<Image Width="26" Height="26">
						<Image.Source>
							<DrawingImage Drawing="{DynamicResource FluentIconsFilled.calendar_empty_filled}" />
						</Image.Source>
					</Image> 
				</Button>
				<Button x:Name="btnDown" Command="{Binding CommandDownButton}">
					<Image Width="26" Height="26">
						<Image.Source>
							<DrawingImage Drawing="{DynamicResource FluentIconsFilled.arrow_down_filled}" />
						</Image.Source>
					</Image> 
				</Button>
			</StackPanel>
		</StackPanel>
	</DockPanel>
</UserControl>
