<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	 		 xmlns:m="using:VesperApp.Models"
			 xmlns:ui="using:FluentAvalonia.UI.Controls"
			 xmlns:si="clr-namespace:SatialInterfaces.Controls;assembly=CalendarControl"
			 xmlns:Controls="using:VesperApp.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VesperApp.Controls.ScheduleEditor">
	<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ColumnDefinitions="*" RowDefinitions="Auto,*" Margin="12" RowSpacing="8">

		<Border Grid.Row="0" Classes="card" Padding="8,6" VerticalAlignment="Stretch">
		<StackPanel Classes="stlToolbar" Orientation="Horizontal"
					HorizontalAlignment="Stretch" VerticalAlignment="Center"
					ScrollViewer.HorizontalScrollBarVisibility="Disabled">

			<Button Classes="icon" Margin="0,0,6,0" Height="42" Width="56" Command="{Binding NewConfigCommand}" x:Name="NewConfigButton" ToolTip.Tip="New configuration">
				<Image Stretch="Uniform" Width="24" Height="24">
					<Image.Source>
						<DrawingImage Drawing="{DynamicResource FluentIconsFilled.form_new_filled}" />
					</Image.Source>
				</Image>
			</Button>
			<Button Classes="icon" Margin="0,0,6,0" Height="42" Width="56" Command="{Binding LoadConfigCommand}" x:Name="LoadConfigButton" ToolTip.Tip="Open configuration">
				<Image Stretch="Uniform" Width="24" Height="24">
					<Image.Source>
						<DrawingImage Drawing="{DynamicResource FluentIconsFilled.open_filled}" />
					</Image.Source>
				</Image>
			</Button>
			<Button Classes="icon" Margin="0,0,6,0" Height="42" Width="56" Command="{Binding SaveConfigCommand}" x:Name="SaveConfigButton" ToolTip.Tip="Save configuration">
				<Image Stretch="Uniform" Width="24" Height="24">
					<Image.Source>
						<DrawingImage Drawing="{DynamicResource FluentIconsFilled.save_filled}" />
					</Image.Source>
				</Image>
			</Button>
			<Border Width="1" Background="{DynamicResource AppStrokeBrush}" Margin="8,4"/>
			<Label FontWeight="SemiBold" Content="Device Type" VerticalAlignment="Center" Margin="0,0,8,0"/>
			<ComboBox x:Name="comboDeviceType"
				VerticalAlignment="Center"
				MinWidth="150"
				ItemsSource="{Binding Source={m:EnumBindingSource {x:Type m:DeviceTypes}}}"
				SelectedItem="{Binding SelectedDeviceType}"/>
		</StackPanel>
		</Border>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<StackPanel Spacing="8">

				<Expander Classes="section" IsExpanded="True" HorizontalAlignment="Stretch">
					<Expander.Header>General</Expander.Header>
					<Grid Margin="2" ColumnDefinitions="Auto,240,48,Auto,Auto" RowDefinitions="Auto,Auto,Auto"
						  RowSpacing="10" ColumnSpacing="8">

						<Label Grid.Row="0" Grid.Column="0" Content="Device Name" VerticalAlignment="Center"/>
						<TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DeviceName}"
								 ToolTip.Tip="Free-text identifier written into the configuration"/>

						<Label Grid.Row="1" Grid.Column="0" Content="Minimum Hardware" VerticalAlignment="Center"/>
						<TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinimumHardware}"
								 ToolTip.Tip="The hardware revision this configuration requires (e.g. 4.0)"/>

						<Label Grid.Row="2" Grid.Column="0" Content="Battery Capacity (mAh)" VerticalAlignment="Center"/>
						<NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding BatteryCapacity}"
									   Minimum="0" Maximum="100000" Increment="10" FormatString="0"
									   ToolTip.Tip="The fitted battery's capacity in mAh (informational, used for estimates)"/>

						<CheckBox Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="2" VerticalAlignment="Center"
								  IsChecked="{Binding IsMagnetOffEnabled}"
								  ToolTip.Tip="Whether a magnet swipe may power the device down in the field">
							Allow Magnet Turn-Off
						</CheckBox>

						<Label Grid.Row="1" Grid.Column="3" Content="Power-On Time/Delay" VerticalAlignment="Center" Margin="0,0,8,0"/>
						<StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="8">
							<MaskedTextBox x:Name="maskPoweron" MinWidth="160" Focusable="True"
										   Text="{Binding PowerOnText, Mode=TwoWay}" Mask="{Binding PowerOnEditMask}"/>
							<CheckBox x:Name="cbIsPoweronRelative" IsThreeState="False" IsChecked="{Binding IsPowerOnRelative}"
									  ToolTip.Tip="When checked, power-on is a relative delay (dd hh:mm:ss, magnet activation is time 0); otherwise an absolute date/time">
								Relative
							</CheckBox>
						</StackPanel>

						<Label Grid.Row="2" Grid.Column="3" Content="Clock Drift" VerticalAlignment="Center" Margin="0,0,8,0"/>
						<NumericUpDown Grid.Row="2" Grid.Column="4" Value="{Binding ClockDrift}" MinWidth="160"
									   Minimum="0" Maximum="4294967295" Increment="1" FormatString="0" Watermark="not set"
									   ToolTip.Tip="Fine RTC clock drift compensation constant for the STM32U585 (clear the field to disable compensation)"/>
					</Grid>
				</Expander>

				<Expander Classes="section" IsExpanded="True" HorizontalAlignment="Stretch">
					<Expander.Header>Schedule</Expander.Header>
					<Controls:ScheduleControl DataContext="{Binding ScheduleViewModel}" HorizontalAlignment="Stretch" Margin="2"/>
				</Expander>

				<Expander Classes="section" IsExpanded="True" HorizontalAlignment="Stretch" VerticalContentAlignment="Stretch">
					<Expander.Header>Sensors</Expander.Header>
					<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
						  ColumnDefinitions="*,2*" ColumnSpacing="8" Margin="2" MinHeight="340">
						<Controls:SelectDeviceDrivers DataContext="{Binding DriversViewModel}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Column="0"/>
						<Controls:DeviceDriverPropertyGrid DataContext="{Binding DriverEditorGridViewModel}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Column="1"/>
					</Grid>
				</Expander>

			</StackPanel>
		</ScrollViewer>

	</Grid>
</UserControl>
