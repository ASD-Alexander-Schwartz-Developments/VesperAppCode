<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VesperApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:m="using:VesperApp.Models"
		xmlns:ui="using:FluentAvalonia.UI.Controls"
		xmlns:Controls="using:VesperApp.Controls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
		MinWidth="860"
		MinHeight="480"
        x:Class="VesperApp.Views.MainView">

	<Design.DataContext>
		<vm:MainViewViewModel/>
	</Design.DataContext>

	<Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">

		<!-- ═══════════════════════ Header ═══════════════════════ -->
		<Border Grid.Row="0" Classes="card" Padding="14,10">
			<Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

				<!-- Brand -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
					<Border Width="36" Height="36" CornerRadius="9" Background="{DynamicResource AppAccentSoftBrush}">
						<Image Source="/Assets/bat.png" Width="22" Height="22"
							   VerticalAlignment="Center" HorizontalAlignment="Center"/>
					</Border>
					<StackPanel VerticalAlignment="Center" Spacing="0">
						<TextBlock Text="Vesper" FontSize="17" FontWeight="SemiBold"/>
						<TextBlock Text="Device Console" Classes="caption"/>
					</StackPanel>
				</StackPanel>

				<!-- Dock connection + controls -->
				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
							HorizontalAlignment="Center" VerticalAlignment="Center">

					<Border Classes="statusPill success" IsVisible="{Binding IsConnected}">
						<StackPanel Orientation="Horizontal" Spacing="7">
							<Ellipse Classes="statusDot" Fill="{DynamicResource SuccessBrush}"/>
							<TextBlock Text="Dock connected" VerticalAlignment="Center"/>
						</StackPanel>
					</Border>
					<Border Classes="statusPill danger" IsVisible="{Binding !IsConnected}">
						<StackPanel Orientation="Horizontal" Spacing="7">
							<Ellipse Classes="statusDot" Fill="{DynamicResource DangerBrush}"/>
							<TextBlock Text="No dock" VerticalAlignment="Center"/>
						</StackPanel>
					</Border>

					<Button Classes="toolbar" Command="{Binding ConnectDisconnectDockCommand}" x:Name="ConnectToggle">
						<StackPanel Orientation="Horizontal" Spacing="7">
							<Image Source="/Assets/connected.png" IsVisible="{Binding IsConnected}" Width="18" Height="18" VerticalAlignment="Center"/>
							<Image Source="/Assets/disconnected.png" IsVisible="{Binding !IsConnected}" Width="18" Height="18" VerticalAlignment="Center"/>
							<TextBlock VerticalAlignment="Center" Text="Connect Dock" IsVisible="{Binding !IsConnected}"/>
							<TextBlock VerticalAlignment="Center" Text="Disconnect Dock" IsVisible="{Binding IsConnected}"/>
						</StackPanel>
					</Button>

					<Border Width="1" Background="{DynamicResource AppStrokeBrush}" Margin="4,3" IsVisible="{Binding IsConnected}"/>

					<StackPanel x:Name="spDockControls" Orientation="Horizontal" Spacing="6"
								IsEnabled="{Binding IsConnected}" IsVisible="{Binding IsConnected}">
						<Button Classes="toolbar" Command="{Binding EnableDeviceDockCommand}" x:Name="DockEnableDeviceToggle">
							<StackPanel Orientation="Horizontal" Spacing="7">
								<Ellipse Classes="statusDot" Fill="{DynamicResource DangerBrush}" IsVisible="{Binding !IsDeviceEnabled}"/>
								<Ellipse Classes="statusDot" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsDeviceEnabled}"/>
								<TextBlock VerticalAlignment="Center" Text="Enable Device" IsVisible="{Binding !IsDeviceEnabled}"/>
								<TextBlock VerticalAlignment="Center" Text="Disable Device" IsVisible="{Binding IsDeviceEnabled}"/>
							</StackPanel>
						</Button>
						<Button Classes="toolbar" Command="{Binding ResetDeviceDockCommand}" x:Name="DockRestDeviceButton" Content="Reset Device"/>
						<Button Classes="toolbar" Command="{Binding Boot0ModeDockCommand}" x:Name="DockBoot0DeviceToggle">
							<StackPanel Orientation="Horizontal" Spacing="7">
								<Ellipse Classes="statusDot" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding IsDeviceBoot0Mode}"/>
								<TextBlock VerticalAlignment="Center" Text="Device Boot" IsVisible="{Binding !IsDeviceBoot0Mode}"/>
								<TextBlock VerticalAlignment="Center" Text="Exit Boot" IsVisible="{Binding IsDeviceBoot0Mode}"/>
							</StackPanel>
						</Button>
					</StackPanel>
				</StackPanel>

				<!-- Clock -->
				<Border Grid.Column="2" Classes="statusPill" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock x:Name="textDateTime" Classes="mono" VerticalAlignment="Center"
								   FontSize="14" Text="{Binding TextDateTimeNow}"/>
						<CheckBox x:Name="chkIsUTC" VerticalAlignment="Center" MinWidth="0"
								  IsChecked="{Binding IsClockUTC}" Content="UTC"/>
					</StackPanel>
				</Border>
			</Grid>
		</Border>

		<!-- ═══════════════════════ Devices ═══════════════════════ -->
		<Border Grid.Row="1" Classes="card" Padding="0">
			<DockPanel LastChildFill="True">

				<Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="14,12,14,8">
					<TextBlock Text="Logger Devices" Classes="sectionHeader" VerticalAlignment="Center"/>
					<Border Grid.Column="1" Classes="statusPill" VerticalAlignment="Center">
						<TextBlock VerticalAlignment="Center">
							<Run Text="{Binding LoggerDevices.Count}"/><Run Text=" detected"/>
						</TextBlock>
					</Border>
				</Grid>

				<!-- Device actions -->
				<Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource AppStrokeBrush}"
						BorderThickness="0,1,0,0" Padding="12,8">
					<WrapPanel Orientation="Horizontal">
						<Button Classes="toolbar" Margin="0,2,6,2" Command="{Binding ConnectDisconnectDeviceCommand}" x:Name="DeviceConnectButton">
							<StackPanel Orientation="Horizontal" Spacing="7">
								<Image Source="/Assets/connected.png" IsVisible="{Binding IsDeviceConnected}" Width="18" Height="18" VerticalAlignment="Center"/>
								<Image Source="/Assets/disconnected.png" IsVisible="{Binding !IsDeviceConnected}" Width="18" Height="18" VerticalAlignment="Center"/>
								<TextBlock VerticalAlignment="Center" Text="Connect Device" IsVisible="{Binding !IsDeviceConnected}"/>
								<TextBlock VerticalAlignment="Center" Text="Disconnect Device" IsVisible="{Binding IsDeviceConnected}"/>
							</StackPanel>
						</Button>
						<Border Width="1" Background="{DynamicResource AppStrokeBrush}" Margin="4,4"/>
						<Button Classes="toolbar" Margin="0,2,6,2" Content="Sleep" Command="{Binding SleepDeviceCommand}" IsEnabled="{Binding IsDeviceConnected}"/>
						<Button Classes="toolbar" Margin="0,2,6,2" Content="Arm Sleep" Command="{Binding ArmSleepDeviceCommand}" IsEnabled="{Binding IsDeviceConnected}"/>
						<Button Classes="toolbar" Margin="0,2,6,2" Content="Format" Command="{Binding FormatDeviceCommand}" IsEnabled="{Binding IsDeviceConnected}"/>
						<Button Classes="toolbar" Margin="0,2,6,2" Content="Set Time" Command="{Binding SetDateTimeDeviceCommand}" IsEnabled="{Binding IsDeviceConnected}"/>
						<Button Classes="toolbar" Margin="0,2,6,2" Content="Upload" Command="{Binding UploadDeviceConfig}" IsEnabled="{Binding IsDeviceConnected}"/>
						<Button Classes="toolbar" Margin="0,2,6,2" Content="Download" Command="{Binding DownloadDeviceData}" IsEnabled="{Binding IsDeviceConnected}"/>
						<Button Classes="toolbar" Margin="0,2,0,2" Content="Upgrade Firmware" Command="{Binding BootloaderDeviceCommand}" IsEnabled="{Binding IsDeviceConnected}"/>
					</WrapPanel>
				</Border>

				<!-- Device list -->
				<ListBox x:Name="listLoggerDevices"
						 ItemsSource="{Binding LoggerDevices}"
						 SelectionMode="Single"
						 Selection="{Binding SelectedLoggerDeviceModel}"
						 Background="Transparent"
						 BorderThickness="0"
						 MinHeight="120" MaxHeight="260"
						 Margin="6,0,6,4">
					<ListBox.Styles>
						<Style Selector="ListBoxItem">
							<Setter Property="Padding" Value="10,4"/>
						</Style>
					</ListBox.Styles>
					<ListBox.Template>
						<ControlTemplate>
							<DockPanel LastChildFill="True">
								<Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBackgroundBrush}"
										BorderBrush="{DynamicResource HeaderBorderBrush}" BorderThickness="0,0,0,1"
										CornerRadius="6,6,0,0" Padding="10,8">
									<Grid ColumnDefinitions="1.4*,*,*,0.7*,0.7*,1.4*,0.9*,0.6*">
										<TextBlock Grid.Column="0" Classes="colHeader" Text="Serial Number"/>
										<TextBlock Grid.Column="1" Classes="colHeader" Text="Name"/>
										<TextBlock Grid.Column="2" Classes="colHeader" Text="Nickname"/>
										<TextBlock Grid.Column="3" Classes="colHeader" Text="HwId"/>
										<TextBlock Grid.Column="4" Classes="colHeader" Text="FwId"/>
										<TextBlock Grid.Column="5" Classes="colHeader" Text="Date / Time"/>
										<TextBlock Grid.Column="6" Classes="colHeader" Text="Disk"/>
										<TextBlock Grid.Column="7" Classes="colHeader" Text="Batt"/>
									</Grid>
								</Border>
								<ScrollViewer x:Name="PART_ScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
									<ItemsPresenter/>
								</ScrollViewer>
							</DockPanel>
						</ControlTemplate>
					</ListBox.Template>
					<ListBox.ItemTemplate>
						<DataTemplate DataType="m:LoggerDevice">
							<Grid ColumnDefinitions="1.4*,*,*,0.7*,0.7*,1.4*,0.9*,0.6*" VerticalAlignment="Center">
								<TextBlock Grid.Column="0" Classes="mono" Text="{Binding SerialNumber}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="2" Text="{Binding Nickname}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="3" Text="{Binding HwId}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="4" Text="{Binding FwId}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="5" Classes="mono" Text="{Binding LocalDateTime}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="6" Text="{Binding DiskStatus}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="7" Text="{Binding BatteryChargePercent}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</DockPanel>
		</Border>

		<!-- ═══════════════════════ Navigation / pages ═══════════════════════ -->
		<Border Grid.Row="2" Classes="surface" Padding="0" ClipToBounds="True">
			<ui:NavigationView x:Name="TabbedNavigationView"
							   PaneDisplayMode="LeftCompact"
							   IsSettingsVisible="False"
							   MenuItemsSource="{Binding Categories}"
							   Content="{Binding CurrentPage}"
							   SelectedItem="{Binding SelectedCategory}">
				<ui:NavigationView.MenuItemTemplateSelector>
					<m:MenuItemTemplateSelector>
						<DataTemplate DataType="{x:Type m:Category}">
							<ui:NavigationViewItem Content="{Binding Name}" IconSource="{Binding Icon}" ToolTip.Tip="{Binding ToolTip}" />
						</DataTemplate>
						<m:MenuItemTemplateSelector.SeparatorTemplate>
							<DataTemplate DataType="{x:Type m:Separator}">
								<ui:NavigationViewItemSeparator />
							</DataTemplate>
						</m:MenuItemTemplateSelector.SeparatorTemplate>
					</m:MenuItemTemplateSelector>
				</ui:NavigationView.MenuItemTemplateSelector>
			</ui:NavigationView>
		</Border>

		<!-- ═══════════════════════ Status bar ═══════════════════════ -->
		<Border Grid.Row="3" Classes="statusBar">
			<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
				<Ellipse Classes="statusDot" Fill="{DynamicResource InfoBrush}"/>
				<TextBlock x:Name="textLogWindow" Classes="subtle" VerticalAlignment="Center"
						   TextTrimming="CharacterEllipsis" Text="{Binding TextMessageBottom}"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
