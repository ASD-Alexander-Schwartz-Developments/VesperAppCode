<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VesperApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:m="using:VesperApp.Models"
		xmlns:si="clr-namespace:SatialInterfaces.Controls;assembly=CalendarControl"
		xmlns:Controls="using:VesperApp.Controls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
		MinWidth="1200"
		MinHeight="800"
        x:Class="VesperApp.Views.MainView">

    <Design.DataContext>
        <vm:MainViewViewModel/>
    </Design.DataContext>


	<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ColumnDefinitions="120,*" RowDefinitions="70,200,*,50"  Margin="5" ShowGridLines="False">
		
		
		<StackPanel VerticalAlignment="Stretch" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
			
			<StackPanel Spacing="1" VerticalAlignment="Center" >
				<Button Margin="10" Command="{Binding ConnectDisconnectDockCommand}" x:Name="ConnectToggle">
					<StackPanel Orientation="Horizontal">
						<Image Source="/Assets/connected.png" IsVisible="{Binding IsConnected}" Width="24"
											  Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" />
						<Image Source="/Assets/disconnected.png" IsVisible="{Binding !IsConnected}" Width="24"
											  Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" />
						<TextBlock VerticalAlignment="Center" Padding="8,2,2,4" Text="Connect Dock" IsVisible="{Binding !IsConnected}" Classes="DockControls"/>
						<TextBlock VerticalAlignment="Center" Padding="8,2,2,4" Text="Disconnect Dock" IsVisible="{Binding IsConnected}" Classes="DockControls"/>
					</StackPanel>
				</Button>
			</StackPanel>
			
			<StackPanel x:Name="spDockControls" Spacing="1" VerticalAlignment="Center" IsEnabled="{Binding IsConnected}" Orientation="Horizontal">
				
				<Button Margin="10" Command="{Binding EnableDeviceDockCommand}" x:Name="DockEnableDeviceToggle">
					<StackPanel Orientation="Horizontal">
						<Ellipse Fill="Red" Width="24" Height="24" IsVisible="{Binding !IsDeviceEnabled}"/>
						<Ellipse Fill="Green" Width="24" Height="24" IsVisible="{Binding IsDeviceEnabled}"/>
						<TextBlock VerticalAlignment="Center" Padding="8,2,2,4" Text="Enable Device" IsVisible="{Binding !IsDeviceEnabled}" Classes="DockControls"/>
						<TextBlock VerticalAlignment="Center" Padding="8,2,2,4" Text="Disable Device" IsVisible="{Binding IsDeviceEnabled}" Classes="DockControls"/>
					</StackPanel>
				</Button>
				<Button Margin="10" Command="{Binding ResetDeviceDockCommand}" x:Name="DockRestDeviceButton">
					<StackPanel Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center" Padding="2,6,2,6" Text="Reset Device" IsVisible="True" Classes="DockControls"/>
					</StackPanel>
				</Button>
				<Button Margin="10" Command="{Binding Boot0ModeDockCommand}" x:Name="DockBoot0DeviceToggle">
					<StackPanel Orientation="Horizontal">
						<Ellipse Fill="Red" Width="24" Height="24" IsVisible="{Binding !IsDeviceBoot0Mode}"/>
						<Ellipse Fill="Green" Width="24" Height="24" IsVisible="{Binding IsDeviceBoot0Mode}"/>
						<TextBlock VerticalAlignment="Center" Padding="8,2,2,4" Text="Device Boot" IsVisible="{Binding !IsDeviceBoot0Mode}" Classes="DockControls"/>
						<TextBlock VerticalAlignment="Center" Padding="8,2,2,4" Text="Device Exit Boot" IsVisible="{Binding IsDeviceBoot0Mode}" Classes="DockControls"/>
					</StackPanel>
				</Button>
			</StackPanel>

				
			<StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Vertical">
				<TextBlock HorizontalAlignment="Right" x:Name="textDateTime" VerticalAlignment="Center" Padding="10,2,2,4" Text="{Binding TextDateTimeNow}" FontFamily="Roboto" FontSize="14"/>
				<CheckBox x:Name="chkIsUTC" IsChecked="{Binding IsClockUTC}" Content="Is UTC" Padding="4,2,2,4"/>
			</StackPanel>

			<StackPanel x:Name="titleBarFlag"  HorizontalAlignment="Right" Orientation="Horizontal"  >
				<Button Margin="10" IsEnabled="{Binding IsUpdateAvailable}" Flyout="{Binding updateFlyout}"  IsVisible="{Binding IsUpdateAvailable}" >
					<StackPanel Orientation="Horizontal">
						<Image Source="/Assets/redFlag.png" Width="25" Height="25" IsVisible="{Binding IsUpdateAvailable}"/>
					</StackPanel>
				</Button >
				<Button Margin="10" IsEnabled="{Binding IsUpdateAvailable}" Flyout="{Binding updateFlyout}"  IsVisible="{Binding isdownloading}" >
					<StackPanel Orientation="Horizontal">
						<Image Source="/Assets/icons8-download-from-cloud-48.png" Width="25" Height="25" IsVisible="{Binding isdownloading}"/>
					</StackPanel>
				</Button >
				<Button Margin="10" IsEnabled="{Binding isdownload}" Flyout="{Binding updateFlyout}"  IsVisible="{Binding isdownload}" >
					<StackPanel Orientation="Horizontal">
						<Image Source="/Assets/icons8-done-48.png" Width="25" Height="25" IsVisible="{Binding isdownload}"/>
					</StackPanel>
				</Button >
			</StackPanel>
		</StackPanel>
		
		
			
		<Border CornerRadius="5" BorderThickness="3"  Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="#909090">
			<Grid ColumnDefinitions="*,100" RowDefinitions="*,40" ShowGridLines="false">
				<ListBox x:Name="listLoggerDevices" ItemsSource="{Binding LoggerDevices}" SelectionMode="Single" Selection="{Binding SelectedLoggerDeviceModel}" ScrollViewer.VerticalScrollBarVisibility="Auto">
					<ListBox.Styles>
						<!-- Give the ListBoxItems a fixed with of 100 and right-align them -->
						<Style Selector="ListBoxItem">
							<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
						</Style>
					</ListBox.Styles>
					<ListBox.Template>
						<ControlTemplate>
							<DockPanel LastChildFill="True" > 
								<Grid DockPanel.Dock="Top" Height="30" ShowGridLines="false" >
									<Grid.ColumnDefinitions>
										<ColumnDefinition MinWidth="100" Width="*"></ColumnDefinition>
										<ColumnDefinition MinWidth="80" Width="*"></ColumnDefinition>
										<ColumnDefinition MinWidth="80" Width="*"></ColumnDefinition>
										<ColumnDefinition MinWidth="30" Width="*"></ColumnDefinition>
										<ColumnDefinition MinWidth="30" Width="*"></ColumnDefinition>
										<ColumnDefinition MinWidth="150" Width="*"></ColumnDefinition>
										<ColumnDefinition MinWidth="40" Width="*"></ColumnDefinition>
										<ColumnDefinition MinWidth="40" Width="*"></ColumnDefinition>
									</Grid.ColumnDefinitions>
									<Label Grid.Column="0" FontWeight="Bold" HorizontalAlignment="Center">Serial Number</Label>
									<Label Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Center">Name</Label>
									<Label Grid.Column="2" FontWeight="Bold" HorizontalAlignment="Center">Nickname</Label>
									<Label Grid.Column="3" FontWeight="Bold" HorizontalAlignment="Center">HwId</Label>
									<Label Grid.Column="4" FontWeight="Bold" HorizontalAlignment="Center">FwId</Label>
									<Label Grid.Column="5" FontWeight="Bold" HorizontalAlignment="Center">Date Time</Label>
									<Label Grid.Column="6" FontWeight="Bold" HorizontalAlignment="Center">Disk Info</Label>
									<Label Grid.Column="7" FontWeight="Bold" HorizontalAlignment="Center">Batt</Label>
								</Grid>
								<ItemsPresenter></ItemsPresenter>
							</DockPanel>
						</ControlTemplate>
					</ListBox.Template>
					<ListBox.ItemTemplate>
						<DataTemplate DataType="m:LoggerDevice">
							<Grid DockPanel.Dock="Bottom" HorizontalAlignment="Stretch" Margin="0,0" ShowGridLines="False">
								<Grid.ColumnDefinitions>
									<ColumnDefinition MinWidth="100" Width="*"></ColumnDefinition>
									<ColumnDefinition MinWidth="80" Width="*"></ColumnDefinition>
									<ColumnDefinition MinWidth="80" Width="*"></ColumnDefinition>
									<ColumnDefinition MinWidth="30" Width="*"></ColumnDefinition>
									<ColumnDefinition MinWidth="30" Width="*"></ColumnDefinition>
									<ColumnDefinition MinWidth="150" Width="*"></ColumnDefinition>
									<ColumnDefinition MinWidth="40" Width="*"></ColumnDefinition>
									<ColumnDefinition MinWidth="40" Width="*"></ColumnDefinition>
								</Grid.ColumnDefinitions>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="0" TextWrapping="Wrap" Padding="1" Text="{Binding SerialNumber}" TextAlignment="Left"/>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="1" TextWrapping="Wrap" Padding="1" Text="{Binding Name}" TextAlignment="Left"/>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="2" TextWrapping="Wrap" Padding="1" Text="{Binding Nickname}" TextAlignment="Left"/>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="3" TextWrapping="Wrap" Padding="1" Text="{Binding HwId}" TextAlignment="Left"/>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="4" TextWrapping="Wrap" Padding="1" Text="{Binding FwId}" TextAlignment="Left"/>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="5" TextWrapping="Wrap" Padding="1" Text="{Binding LocalDateTime}" TextAlignment="Left"/>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="6" TextWrapping="Wrap" Padding="1" Text="{Binding DiskStatus}" TextAlignment="Left"/>
								<TextBlock HorizontalAlignment="Stretch" Grid.Column="7" TextWrapping="Wrap" Padding="1" Text="{Binding BatteryChargePercent}" TextAlignment="Left"/>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>


				<StackPanel IsEnabled="True" Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Spacing="5" Margin="10,1,1,1" HorizontalAlignment="Center">

					<Button Margin="1" Height="30" Command="{Binding ConnectDisconnectDeviceCommand}" x:Name="DeviceConnectButton">
						<StackPanel Orientation="Horizontal">
							<Image Source="/Assets/connected.png" IsVisible="{Binding IsDeviceConnected}" Width="24"
												  Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" />
							<Image Source="/Assets/disconnected.png" IsVisible="{Binding !IsDeviceConnected}" Width="24"
												  Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" />
							<TextBlock VerticalAlignment="Center" Padding="6,0,0,0" Text="Connect Device" IsVisible="{Binding !IsDeviceConnected}" Classes="DeviceControls"/>
							<TextBlock VerticalAlignment="Center" Padding="6,0,0,0" Text="Disconnect Device" IsVisible="{Binding IsDeviceConnected}" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

					<Button Margin="1" Height="30" Command="{Binding SleepDeviceCommand}" x:Name="bSleepDeviceButton" IsEnabled="{Binding IsDeviceConnected}">
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center" Text="Sleep" IsVisible="True" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

					<Button Margin="1" Height="30" Command="{Binding ArmSleepDeviceCommand}" x:Name="bArmSleepDeviceButton" IsEnabled="{Binding IsDeviceConnected}">
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center" Text="Arm Sleep" IsVisible="True" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

					<Button Margin="1" Height="30" Command="{Binding FormatDeviceCommand}" x:Name="bFormatDeviceButton" IsEnabled="{Binding IsDeviceConnected}">
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center" Text="Format" IsVisible="True" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

					<Button Margin="1" Height="30" Command="{Binding SetDateTimeDeviceCommand}" x:Name="bSetDateTimeDeviceButton" IsEnabled="{Binding IsDeviceConnected}">
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center" Text="Set Time" IsVisible="True" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

					<Button Margin="1" Height="30" Command="{Binding UploadDeviceConfig}" x:Name="bUploadDeviceConfigButton" IsEnabled="{Binding IsDeviceConnected}">
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center" Text="Upload" IsVisible="True" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

					<Button Margin="1" Height="30" Command="{Binding DownloadDeviceData}" x:Name="bDownloadDeviceDataButton" IsEnabled="{Binding IsDeviceConnected}">
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center" Text="Download" IsVisible="True" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

					<Button Margin="1" Height="30" Command="{Binding BootloaderDeviceCommand}" x:Name="bBootloadDeviceButton" IsEnabled="{Binding IsDeviceConnected}">
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center" Text="Upgrade Firmware" IsVisible="True" Classes="DeviceControls"/>
						</StackPanel>
					</Button>

				</StackPanel>

				<StackPanel Spacing="1" Orientation="Horizontal" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2">
					<ListBox ItemsSource="{Binding Source={m:EnumBindingSource {x:Type m:DeviceTypes}}}" 
							 SelectionMode="Multiple,Toggle" 
							 Selection="{Binding DevicesFiltersSelection}" 
							 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Border CornerRadius="3" Margin="1,3,10,3" Padding="3,3,3,3" >
									<TextBlock FontWeight="Medium" Text="{Binding .}" TextWrapping="Wrap"/>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</StackPanel>


			</Grid>
		</Border>
					

		<Border Classes="tabBorder" BorderThickness="3" CornerRadius="5" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" HorizontalAlignment="Stretch" Padding="0">
			<TabControl TabStripPlacement="Left" VerticalContentAlignment="Stretch" HorizontalAlignment="Stretch">
				<TabItem>
					<TabItem.Header>
						<TextBlock Classes="tbTabHeader" Text="Recordings" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
					</TabItem.Header>
						<Grid HorizontalAlignment="Stretch" ColumnDefinitions="*" RowDefinitions="60,*" ShowGridLines="true">
							<StackPanel Classes="stlToolbar" Grid.Column="0" Grid.Row="0" Orientation="Horizontal"
										HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
										ScrollViewer.HorizontalScrollBarVisibility="Disabled">
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding ManualGPSParserCommand}" x:Name="bParseGPS" ToolTip.Tip="GPS Decoder">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.globe_location_filled}" />
											</Image.Source>
										</Image> 
									</StackPanel>
								</Button>
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding ManualAudioParserCommand}" x:Name="bParseAudio" ToolTip.Tip="Audio Decoder">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.sound_source_filled}" />
											</Image.Source>
										</Image>
									</StackPanel>
								</Button>
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding ManualTprhParserCommand}" x:Name="bParseTprh" ToolTip.Tip="Teperature/Humidity Decoder">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.temperature_filled}" />
											</Image.Source>
										</Image>
									</StackPanel>
								</Button>
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding ManualAlsParserCommand}" x:Name="bParseAls" ToolTip.Tip="Ambient Light Decoder">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.flashlight_filled}" />
											</Image.Source>
										</Image>
									</StackPanel>
								</Button>
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding ManualMotionParserCommand}" x:Name="bParseImu" ToolTip.Tip="IMU (Innertial Motion Unit) Sensor Decoder">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.directions_filled}" />
											</Image.Source>
										</Image>
									</StackPanel>
								</Button>
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding ManualEXG48ParserCommand}" x:Name="bParseBio" ToolTip.Tip="EXG48 (4ch/8ch ECG/EMG/EEG) Sensor Decoder">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.bio}" />
											</Image.Source>
										</Image>
									</StackPanel>
								</Button>
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding ManualEXG1292ParserCommand}" x:Name="bParseExg1292" ToolTip.Tip="EXG1292 (2ch ECG/EMG/EEG) Sensor Decoder">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.bio}" />
											</Image.Source>
										</Image>
									</StackPanel>
								</Button>
								<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding BinaryFilesExtractor}" x:Name="bParseBinaries" ToolTip.Tip="Extract Content files from Vesper/Pipistrelle binary files">
									<StackPanel Orientation="Horizontal">
										<Image Stretch="Fill" Width="42" Height="42">
											<Image.Source>
												<DrawingImage Drawing="{DynamicResource FluentIconsFilled.folder_briefcase_filled}" />
											</Image.Source>
										</Image>
										<ProgressBar x:Name="ProgressBinaryParser" IsVisible="{Binding BinaryParserIsRunning}" Value="{Binding BinaryParserPercent}"/>
									</StackPanel>
								</Button>
							</StackPanel>
						</Grid>
				</TabItem>
				<TabItem>
					<TabItem.Header>
						<TextBlock Classes="tbTabHeader" Text="Config" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
					</TabItem.Header>
					<Grid HorizontalAlignment="Stretch" ColumnDefinitions="*" RowDefinitions="60,*" ShowGridLines="true">
						<StackPanel Classes="stlToolbar" Grid.Column="0" Grid.Row="0" Orientation="Horizontal" 
									HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
									ScrollViewer.HorizontalScrollBarVisibility="Disabled">

							<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding NewConfigCommand}" x:Name="NewConfigButton">
								<StackPanel Orientation="Horizontal">
									<Image Stretch="Fill" Width="42" Height="42">
										<Image.Source>
											<DrawingImage Drawing="{DynamicResource FluentIconsFilled.form_new_filled}" />
										</Image.Source>
									</Image> 
								</StackPanel>
							</Button>
							<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding LoadConfigCommand}" x:Name="LoadConfigButton">
								<StackPanel Orientation="Horizontal">
									<Image Stretch="Fill" Width="42" Height="42">
										<Image.Source>
											<DrawingImage Drawing="{DynamicResource FluentIconsFilled.open_filled}" />
										</Image.Source>
									</Image> 
								</StackPanel>
							</Button>
							<Button Margin="5" CornerRadius="5" Height="42" Width="64" Command="{Binding SaveConfigCommand}" x:Name="SaveConfigButton">
								<StackPanel Orientation="Horizontal">
									<Image Stretch="Fill" Width="42" Height="42">
										<Image.Source>
											<DrawingImage Drawing="{DynamicResource FluentIconsFilled.save_filled}" />
										</Image.Source>
									</Image>
								</StackPanel>
							</Button>
							<Separator Margin="10"/>
							<Label FontWeight="Bold" Content="Select Device Type" VerticalAlignment="Center"/>
							<ComboBox x:Name="comboDeviceType"
								Margin="1"
								VerticalAlignment="Center"
								Width="120"
								ItemsSource="{Binding Source={m:EnumBindingSource {x:Type m:DeviceTypes}}}"
								SelectedItem="{Binding SelectedDeviceType}"/>
						</StackPanel>

						<StackPanel Grid.Column="0" Grid.Row="1">
							<Expander VerticalAlignment="Top" HorizontalAlignment="Stretch">
								<Expander.Header>
									Schedule
								</Expander.Header>
								<Controls:ScheduleControl DataContext="{Binding ScheduleViewModel}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Padding="1" Margin="1" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2"/>
							</Expander>
							<Expander VerticalAlignment="Bottom" HorizontalAlignment="Stretch" VerticalContentAlignment="Stretch">
								<Expander.Header>
									Sensors
								</Expander.Header>
								<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
								  ColumnDefinitions="*,2*" Margin="5" ShowGridLines="False">
									<Controls:SelectDeviceDrivers DataContext="{Binding DriversViewModel}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Padding="1" Margin="1" Grid.Row="0" Grid.Column="0"/>
									<Controls:DeviceDriverPropertyGrid DataContext="{Binding DriverEditorGridViewModel}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Padding="1" Margin="1" Grid.Row="0" Grid.Column="1"/>
								</Grid>
							</Expander>
						</StackPanel>
					</Grid>
				</TabItem>
				<TabItem>
					<TabItem.Header>
						<TextBlock Classes="tbTabHeader" Text="Help" HorizontalAlignment="Left" VerticalAlignment="Center"/>
					</TabItem.Header>

					<StackPanel>
						<TextBlock Text="Coming Soon"/>
					</StackPanel>
				</TabItem>
				<TabItem>
					<TabItem.Header>
						<TextBlock Classes="tbTabHeader" Text="Properties" HorizontalAlignment="Left" VerticalAlignment="Center"/>
					</TabItem.Header>

					<StackPanel>
						<TextBlock Text="Hello4"/>
					</StackPanel>
				</TabItem>
			</TabControl>
		</Border>
		<Border BorderThickness="1" CornerRadius="5" Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" Padding="0,1">
			<Grid Margin="1">
				<TextBlock HorizontalAlignment="Stretch" VerticalAlignment="Stretch" x:Name="textLogWindow" Text="{Binding IsConnected}"/>
			</Grid>
		</Border>		
	</Grid>
	
	
</UserControl>
