# VesperApp — device access for non-root users on Linux.
#
# Install:
#   sudo cp 70-vesperapp.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
# then unplug and replug the devices.
#
# TAG+="uaccess" grants access to the locally logged-in user on systemd distros
# (Ubuntu, Fedora, ...). GROUP="plugdev" is a fallback for distros that have that
# group; where it does not exist the line is harmless.
# Keep this file numbered below 73 so the uaccess tag is applied by
# 73-seat-late.rules.

# Docking station (FTDI FT232R — CBUS bit-bang via libusb)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", MODE="0660", GROUP="plugdev", TAG+="uaccess"

# KOL / Vesper / Pipistrelle loggers (USB CDC serial, ST-licensed PID)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="a4f4", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# Legacy PIDs used by older firmware
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5710", MODE="0660", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="570f", MODE="0660", GROUP="plugdev", TAG+="uaccess"

# STM32 DFU bootloader (firmware flashing through the dock)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", MODE="0660", GROUP="plugdev", TAG+="uaccess"

# Nanotag (Microchip bootloader)
SUBSYSTEM=="usb", ATTRS{idVendor}=="04d8", ATTRS{idProduct}=="fe57", MODE="0660", GROUP="plugdev", TAG+="uaccess"
