<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:local="using:VesperApp"
			 xmlns:sty="using:FluentAvalonia.Styling"
			 x:Class="VesperApp.App">
	<Application.DataTemplates>
		<local:ViewLocator/>
	</Application.DataTemplates>

	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://VesperApp/Assets/ResourceDictionary.axaml"/>
				<!-- Shared resources and common styles -->
				<ResourceInclude Source="avares://VesperApp/Assets/SharedResources.axaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>
	<!-- Keep application-level styles and include shared resources -->
	<Application.Styles>
		<sty:FluentAvaloniaTheme />
		<StyleInclude Source="avares://VesperApp/Assets/FluentUiIcons_Filled.xaml"/>



		<!-- Text styles
		<Style x:Key="HeaderText" Selector="TextBlock">
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="Margin" Value="12,0,12,0"/>
		</Style>-->

		<!-- Shared styles (ListBox/ListView full-row selection, header helpers) -->
		<Style Selector="ListBoxItem">
			<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="MinHeight" Value="{StaticResource ListRowMinHeight}"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Style Selector="^:pointerover">
				<Setter Property="Background" Value="{StaticResource ListItemPointerOverBrush}"/>
			</Style>
			<Style Selector="^:selected">
				<Setter Property="Background" Value="{StaticResource ListItemSelectedBrush}"/>
				<Setter Property="Foreground" Value="{StaticResource ListItemSelectedForegroundBrush}"/>
			</Style>
		</Style>

		<!-- Small utility styles -->
		<Style Selector="StackPanel.collapseAnimation">
			<Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.2" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Border.Clock">
			<Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorLight1}"/>
		</Style>
		<Style Selector="Border.devBorder">
			<Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark1}"/>
		</Style>
		<Style Selector="Border.tabBorder">
			<Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark2}"/>
		</Style>


		<!-- ───────── Reusable surface + typography styles (opt-in via Classes) ───────── -->

		<!-- Card surface: rounded, subtly bordered, soft shadow. Theme-aware. -->
		<Style Selector="Border.card">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16"/>
			<Setter Property="BoxShadow" Value="0 2 10 0 #18000000"/>
		</Style>

		<!-- A full page surface: comfortable padding around content. -->
		<Style Selector="Border.page">
			<Setter Property="Padding" Value="16"/>
		</Style>

		<!-- Typography helpers -->
		<Style Selector="TextBlock.pageTitle">
			<Setter Property="FontSize" Value="22"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Margin" Value="0,0,0,2"/>
		</Style>
		<Style Selector="TextBlock.sectionHeader">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>
		<Style Selector="TextBlock.caption">
			<Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
			<Setter Property="FontSize" Value="12.5"/>
			<Setter Property="TextWrapping" Value="Wrap"/>
		</Style>

		<!-- Slim, rounded progress bars used across decoders/updaters. -->
		<Style Selector="ProgressBar.slim">
			<Setter Property="Height" Value="6"/>
			<Setter Property="CornerRadius" Value="3"/>
			<Setter Property="MinHeight" Value="6"/>
		</Style>

		<!-- Expander headers a touch bolder for the configuration editor. -->
		<Style Selector="Expander.section /template/ ToggleButton#ExpanderHeader TextBlock">
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>

		<!-- Any additional app-specific styles can remain here -->
		<Style Selector="Button">
			<!-- App-wide button tweaks can live here -->
		</Style>
	</Application.Styles>

	<NativeMenu.Menu>
		<NativeMenu />
	</NativeMenu.Menu>
</Application>
